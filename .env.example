PORT=3000
APP_VERSION=0.1.1
PUBLIC_BASE_URL=
ENABLE_DEMO_RESET=true
COMMITTEE_2FA_CODE=123456
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1

# Docker Compose local database defaults.
DATABASE_URL=postgres://smartneighbor:smartneighbor@postgres:5432/smartneighbor
REDIS_URL=redis://redis:6379

# Telegram Bot API. Create a bot with BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=smartneighbor-telegram-dev-secret

# PayPal Sandbox. Leave empty to use the built-in mock capture flow.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# BIT/Open Banking. Leave as simulator unless you have real TPP credentials and signing certificates.
BIT_MODE=simulator
BIT_CLIENT_ID=
BIT_CLIENT_SECRET=
BIT_PAYMENT_PRODUCT=domestic-credit-transfers
BIT_TPP_CERTIFICATE=
BIT_PRIVATE_KEY=
