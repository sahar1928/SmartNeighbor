PORT=3000
APP_VERSION=0.1.0
PUBLIC_BASE_URL=

# Docker Compose local database defaults.
DATABASE_URL=postgres://smartneighbor:smartneighbor@postgres:5432/smartneighbor
REDIS_URL=redis://redis:6379

# Any random secret you type both here and in Meta's webhook setup screen.
WHATSAPP_VERIFY_TOKEN=smartneighbor-dev-token

# From Meta Developers > WhatsApp > API Setup.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v24.0

# Your test recipient number, without + or dashes. +97252-5452532 becomes:
WHATSAPP_DEFAULT_TO=972525452532

# PayPal Sandbox. Leave empty to use the built-in mock capture flow.
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# BIT/Open Banking. Leave as simulator unless you have real TPP credentials and signing certificates.
BIT_MODE=simulator
BIT_CLIENT_ID=
BIT_CLIENT_SECRET=
BIT_PAYMENT_PRODUCT=domestic-credit-transfers
BIT_TPP_CERTIFICATE=
BIT_PRIVATE_KEY=
